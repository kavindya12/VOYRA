# Copy to .env and fill in your values (do not commit .env)

# Supabase — Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Legacy anon JWT (alternative to publishable key)
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — for npm run upload:hero-videos (service_role; never commit)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: hero video URLs (comma-separated)
# VITE_HERO_VIDEOS=

# Optional: Google Custom Search for galleries
# VITE_GOOGLE_CSE_API_KEY=
# VITE_GOOGLE_CSE_CX=
