VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Legacy name (also supported)
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only: upload hero videos with `node scripts/upload-hero-videos.mjs` (never commit this key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: hero video URLs (comma-separated). If unset, uses Supabase Storage bucket "hero-videos" or /public/videos/
# VITE_HERO_VIDEOS=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/hero-videos/hero-1.mp4,...

# Optional: Google Custom Search for live destination photos (tour detail gallery)
# Create at https://programmablesearchengine.google.com/ (enable Image search)
# VITE_GOOGLE_CSE_API_KEY=your-api-key
# VITE_GOOGLE_CSE_CX=your-search-engine-id
